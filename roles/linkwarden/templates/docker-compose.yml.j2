services:
  app:
    image: "ghcr.io/linkwarden/linkwarden:{{ linkwarden_image_tag }}"
    container_name: "linkwarden"
    restart: unless-stopped
    depends_on:
      - db
      - meilisearch
    security_opt:
      - no-new-privileges:true
    volumes:
      - ./data:/data/data
    networks:
      - proxy
      - linkwarden_internal
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.linkwarden.rule=Host(`linkwarden.{{ traefik_domain }}`)"
      - "traefik.http.routers.linkwarden.entrypoints=websecure"
      - "traefik.http.routers.linkwarden.tls=true"
      - "traefik.http.services.linkwarden.loadbalancer.server.port=3000"
    environment:
      DATABASE_URL: "{{ linkwarden_database_url }}"
      NEXTAUTH_URL: "https://linkwarden.{{ traefik_domain }}/api/v1/auth"
      NEXTAUTH_SECRET: "{{ linkwarden_nextauth_secret }}"
      NEXT_PUBLIC_DISABLE_REGISTRATION: true

  db:
    image: "postgres:{{ linkwarden_postgres_image_tag }}"
    container_name: linkwarden_db
    security_opt:
      - no-new-privileges:true
    volumes:
      - ./db_data:/var/lib/postgresql/data
    restart: unless-stopped
    networks:
      - linkwarden_internal
    environment:
      POSTGRES_DB: postgres
      POSTGRES_USER: "{{ linkwarden_db_user }}"
      POSTGRES_PASSWORD: "{{ linkwarden_db_password }}"

  meilisearch:
    image: "getmeili/meilisearch:{{ linkwarden_meilisearch_image_tag }}"
    container_name: linkwarden_meilisearch
    security_opt:
      - no-new-privileges:true
    restart: unless-stopped
    volumes:
      - ./meili_data:/meili_data
    networks:
      - linkwarden_internal
    environment:
      MEILI_MASTER_KEY: "{{ linkwarden_meilisearch_master_key }}"

networks:
  proxy:
    external: true
  linkwarden_internal:
    name: linkwarden_internal
    internal: true
