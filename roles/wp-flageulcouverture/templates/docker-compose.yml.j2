---

services:
  app:
    image: "{{ wp_flageulcouverture_app_image }}:{{ wp_flageulcouverture_app_image_tag }}"
    restart: always
    depends_on:
      - db
    security_opt:
      - no-new-privileges:true
    volumes:
      - ./src:/var/www/html
      - ./config/php.ini:/usr/local/etc/php/conf.d/php.ini
    networks:
      - "{{ wp_flageulcouverture_reverse_proxy_network }}"
      - "{{ wp_flageulcouverture_role_name }}_internal"
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{ wp_flageulcouverture_role_name }}.rule=Host(`{{ wp_flageulcouverture_web_url }}`)"
      - "traefik.http.routers.{{ wp_flageulcouverture_role_name }}.entrypoints=websecure"
      - "traefik.http.routers.{{ wp_flageulcouverture_role_name }}.tls=true"
      - "traefik.http.routers.{{ wp_flageulcouverture_role_name }}.tls.certresolver=letsencrypt-http"
      - "traefik.http.services.{{ wp_flageulcouverture_role_name }}.loadbalancer.server.port=80"
    environment:
      WORDPRESS_DB_HOST: db
      WORDPRESS_DB_NAME: "{{ wp_flageulcouverture_db_name }}"
      WORDPRESS_DB_PASSWORD: "{{ wp_flageulcouverture_db_password }}"
      WORDPRESS_DB_USER: "{{ wp_flageulcouverture_db_user }}"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost/wp-login.php"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 20s

  db:
    image: "{{ wp_flageulcouverture_mysql_image }}:{{ wp_flageulcouverture_mysql_image_tag }}"
    restart: always
    security_opt:
      - no-new-privileges:true
    volumes:
      - ./db_data:/var/lib/mysql
    networks:
      - "{{ wp_flageulcouverture_role_name }}_internal"
    labels:
      - "kopia.backup.target=true"
    environment:
      MYSQL_DATABASE: "{{ wp_flageulcouverture_db_name }}"
      MYSQL_USER: "{{ wp_flageulcouverture_db_user }}"
      MYSQL_PASSWORD: "{{ wp_flageulcouverture_db_password }}"
      MYSQL_RANDOM_ROOT_PASSWORD: true
    healthcheck:
      test: ["CMD-SHELL", "mysqladmin ping -h localhost -u $$MYSQL_USER -p$$MYSQL_PASSWORD"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

networks:
  "{{ wp_flageulcouverture_reverse_proxy_network }}":
    external: true
  "{{ wp_flageulcouverture_role_name }}_internal":
    name: "{{ wp_flageulcouverture_role_name }}_internal"
    internal: true
