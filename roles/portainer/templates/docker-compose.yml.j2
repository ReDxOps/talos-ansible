---

services:
  portainer:
    image: portainer/portainer-ce:{{ portainer_image_tag }}
    container_name: "{{ portainer_role_name }}"
    command: 
      - "--admin-password={{ portainer_admin_password_hash | replace('$', '$$') }}"
    restart: always
    security_opt:
      - no-new-privileges:true
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - ./data:/data
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - "{{ portainer_reverse_proxy_network }}"
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ portainer_reverse_proxy_network }}"
      - "traefik.http.routers.{{ portainer_role_name }}.rule=Host(`{{ portainer_web_url }}`)"
      - "traefik.http.routers.{{ portainer_role_name }}.entrypoints=websecure"
      - "traefik.http.routers.{{ portainer_role_name }}.tls=true"
      - "traefik.http.services.{{ portainer_role_name }}.loadbalancer.server.port=9000"

networks:
  "{{ portainer_reverse_proxy_network }}":
    external: true