# IN application vars
APP_URL="https://{{ invoiceninja_hestia_web_url }}"
APP_KEY="{{ invoiceninja_hestia_app_key }}"
APP_ENV="{{ invoiceninja_hestia_app_env }}"
APP_DEBUG="{{ invoiceninja_hestia_app_debug }}"
REQUIRE_HTTPS=true
PHANTOMJS_PDF_GENERATION=false
PDF_GENERATOR=snappdf
TRUSTED_PROXIES='*'

# Cache application configuration
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# REDIS Configuration
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

FILESYSTEM_DISK=debian_docker

# DB connection
DB_HOST=db
DB_CONNECTION=mysql
DB_PORT="{{ invoiceninja_hestia_db_port }}"
DB_DATABASE="{{ invoiceninja_hestia_db_name }}"
DB_USERNAME="{{ invoiceninja_hestia_db_user }}"
DB_PASSWORD="{{ invoiceninja_hestia_db_password }}"

# Create initial user
IN_USER_EMAIL="{{ invoiceninja_hestia_initial_user_email }}"
IN_PASSWORD="{{ invoiceninja_hestia_initial_user_password }}"

# Mail options

MAIL_MAILER="{{ invoiceninja_hestia_smtp_mailer }}"
MAILGUN_DOMAIN="{{ invoiceninja_hestia_smtp_domain }}"
MAILGUN_SECRET="{{ invoiceninja_hestia_smtp_api_key }}"
MAILGUN_ENDPOINT="{{ invoiceninja_hestia_smtp_endpoint_url }}"
MAIL_FROM_ADDRESS="{{ invoiceninja_hestia_smtp_send_from_address }}"
MAIL_FROM_NAME="{{ invoiceninja_hestia_smtp_send_from_name }}"


IS_DOCKER=true
SCOUT_DRIVER=null

