---

services:
  app:
    image: "{{ passbolt_app_image }}:{{ passbolt_app_image_tag }}"
    restart: always
    depends_on:
      - db
    security_opt:
      - no-new-privileges:true
    volumes:
      - ./gpg_volume:/etc/passbolt/gpg
      - ./jwt_volume:/etc/passbolt/jwt
    networks:
      - "{{ passbolt_reverse_proxy_network }}"
      - "{{ passbolt_role_name }}_internal"
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ passbolt_reverse_proxy_network }}"
      - "traefik.http.routers.{{ passbolt_role_name }}.rule=Host(`{{ passbolt_web_url }}`)"
      - "traefik.http.routers.{{ passbolt_role_name }}.entrypoints=websecure"
      - "traefik.http.routers.{{ passbolt_role_name }}.tls=true"
      - "traefik.http.routers.{{ passbolt_role_name }}.tls.certresolver=letsencrypt-dns"
      - "traefik.http.services.{{ passbolt_role_name }}.loadbalancer.server.port=8080"
    environment:
      APP_FULL_BASE_URL: "https://{{ passbolt_web_url }}"

      DATASOURCES_DEFAULT_HOST: "db"
      DATASOURCES_DEFAULT_DATABASE: "{{ passbolt_db_name }}"
      DATASOURCES_DEFAULT_USERNAME: "{{ passbolt_db_user }}"
      DATASOURCES_DEFAULT_PASSWORD: "{{ passbolt_db_password }}"

      EMAIL_TRANSPORT_DEFAULT_HOST: "{{ passbolt_smtp_host }}"
      EMAIL_TRANSPORT_DEFAULT_PORT: "{{ passbolt_smtp_port }}"
      EMAIL_DEFAULT_FROM: "{{ passbolt_email_sender }}"
      EMAIL_TRANSPORT_DEFAULT_USERNAME: "{{ passbolt_smtp_user }}"
      EMAIL_TRANSPORT_DEFAULT_PASSWORD: "{{ passbolt_smtp_password }}"

      PASSBOLT_KEY_NAME: "{{ passbolt_send_name }}"
      PASSBOLT_KEY_EMAIL: "{{ passbolt_email_sender }}"

      PASSBOLT_SSL_FORCE: "{{ passbolt_ssl_force }}"
      PASSBOLT_TRUSTED_PROXIES: "172.18.0.0/16"

    command: [ "/usr/bin/wait-for.sh", "-t", "0", "db:3306", "--", "/docker-entrypoint.sh" ]

    healthcheck:
      test: ["CMD", "curl", "-fs", "http://127.0.0.1:8080"]
      interval: 10s
      timeout: 5s
      retries: 5

  db:
    image: "{{ passbolt_mariadb_image }}:{{ passbolt_mariadb_image_tag }}"
    restart: always
    stop_grace_period: 1m
    security_opt:
      - no-new-privileges:true
    volumes:
      - ./db_data:/var/lib/mysql
    networks:
      - "{{ passbolt_role_name }}_internal"
    labels:
      - "kopia.backup.target=true"
    environment:
      MYSQL_RANDOM_ROOT_PASSWORD: "true"
      MYSQL_DATABASE: "{{ passbolt_db_name }}"
      MYSQL_USER: "{{ passbolt_db_user }}"
      MYSQL_PASSWORD: "{{ passbolt_db_password }}"
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 30s


networks:
  "{{ passbolt_reverse_proxy_network }}":
    external: true
  "{{ passbolt_role_name }}_internal":
    name: "{{ passbolt_role_name }}_internal"
    internal: true
