# IN application vars
APP_URL="https://{{ invoiceninja_web_url }}"
APP_KEY="{{ invoiceninja_app_key }}"
APP_ENV="{{ invoiceninja_app_env }}"
APP_DEBUG="{{ invoiceninja_app_debug }}"
REQUIRE_HTTPS=true
PHANTOMJS_PDF_GENERATION=false
PDF_GENERATOR=snappdf
TRUSTED_PROXIES='*'

# Cache application configuration
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# REDIS Configuration
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

FILESYSTEM_DISK=debian_docker

# DB connection
DB_HOST=db
DB_CONNECTION=mysql
DB_PORT="{{ invoiceninja_db_port }}"
DB_DATABASE="{{ invoiceninja_db_name }}"
DB_USERNAME="{{ invoiceninja_db_user }}"
DB_PASSWORD="{{ invoiceninja_db_password }}"

# Create initial user
IN_USER_EMAIL="{{ invoiceninja_initial_user_email }}"
IN_PASSWORD="{{ invoiceninja_initial_user_password }}"

# Mail options
MAIL_MAILER=smtp
MAIL_HOST="{{ invoiceninja_smtp_host }}"
MAIL_PORT="{{ invoiceninja_smtp_port }}"
MAIL_USERNAME="{{ invoiceninja_smtp_username }}"
MAIL_PASSWORD="{{ invoiceninja_smtp_password }}"
MAIL_ENCRYPTION="{{ invoiceninja_smtp_encryption }}"
MAIL_FROM_ADDRESS="{{ invoiceninja_smtp_send_from_address }}"
MAIL_FROM_NAME="{{ invoiceninja_smtp_send_from_name }}"


IS_DOCKER=true
SCOUT_DRIVER=null

