---

services:
  app:
    image: "{{ vikunja_app_image }}:{{ vikunja_app_image_tag }}"
    restart: always
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy

    security_opt:
      - no-new-privileges:true
    volumes:
      - ./data:/app/vikunja/files
    networks:
      - "{{ vikunja_reverse_proxy_network }}"
      - "{{ vikunja_role_name }}_internal"
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ vikunja_reverse_proxy_network }}"
      - "traefik.http.routers.{{ vikunja_role_name }}.rule=Host(`{{ vikunja_web_url }}`)"
      - "traefik.http.routers.{{ vikunja_role_name }}.middlewares=secHeaders@file,tailscaleOnly@file"
      - "traefik.http.routers.{{ vikunja_role_name }}.entrypoints=websecure"
      - "traefik.http.routers.{{ vikunja_role_name }}.tls=true"
      - "traefik.http.routers.{{ vikunja_role_name }}.tls.certresolver=letsencrypt-dns"
      - "traefik.http.services.{{ vikunja_role_name }}.loadbalancer.server.port=3456"
    environment:
      VIKUNJA_SERVICE_PUBLICURL: "https://vikunja.{{ traefik_domain }}"
      HOME: /app/vikunja/files
      VIKUNJA_DATABASE_HOST: db
      VIKUNJA_DATABASE_TYPE: postgres
      VIKUNJA_DATABASE_DATABASE: "{{ vikunja_db_name }}"
      VIKUNJA_DATABASE_USER: "{{ vikunja_db_user }}"
      VIKUNJA_DATABASE_PASSWORD: "{{ vikunja_db_password }}"
      VIKUNJA_REDIS_ENABLED: "true"
      VIKUNJA_REDIS_HOST: "redis:6379"
      VIKUNJA_SERVICE_TIMEZONE: Europe/Paris
    healthcheck:
      test: ["CMD", "/app/vikunja/vikunja", "version"]
      interval: 30s
      timeout: 10s
      retries: 3

  db:
    image: "{{ vikunja_postgres_image }}:{{ vikunja_postgres_image_tag }}"
    security_opt:
      - no-new-privileges:true
    volumes:
      - ./db_data:/var/lib/postgresql/data
    restart: always
    networks:
      - "{{ vikunja_role_name }}_internal"
    labels:
      - "kopia.backup.target=true"
    environment:
      POSTGRES_DB: "{{ vikunja_db_name }}"
      POSTGRES_USER: "{{ vikunja_db_user }}"
      POSTGRES_PASSWORD: "{{ vikunja_db_password }}"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER} -d $${POSTGRES_DB}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s

  redis:
    image: "{{ vikunja_redis_image }}:{{ vikunja_redis_image_tag }}"
    restart: always
    security_opt:
      - no-new-privileges:true
    networks:
      - "{{ vikunja_role_name }}_internal"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

networks:
  "{{ vikunja_reverse_proxy_network }}":
    external: true
  "{{ vikunja_role_name }}_internal":
    name: "{{ vikunja_role_name }}_internal"
    internal: true
