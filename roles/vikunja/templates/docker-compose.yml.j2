services:
  app:
    image: "vikunja/vikunja:{{ vikunja_image_tag }}"
    container_name: "vikunja"
    restart: unless-stopped
    depends_on:
      - db
      - redis
    security_opt:
      - no-new-privileges:true
    volumes:
      - ./data:/app/vikunja/files
    networks:
      - proxy
      - "vikunja_internal"
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.vikunja.rule=Host(`vikunja.{{ traefik_domain }}`)"
      - "traefik.http.routers.vikunja.entrypoints=websecure"
      - "traefik.http.routers.vikunja.tls=true"
      - "traefik.http.services.vikunja.loadbalancer.server.port=3456"
    environment:
      VIKUNJA_SERVICE_PUBLICURL: "https://vikunja.{{ traefik_domain }}"
      HOME: /app/vikunja/files
      VIKUNJA_DATABASE_HOST: db
      VIKUNJA_DATABASE_TYPE: postgres
      VIKUNJA_DATABASE_DATABASE: vikunja
      VIKUNJA_DATABASE_USER: "{{ vikunja_db_user }}"
      VIKUNJA_DATABASE_PASSWORD: "{{ vikunja_db_password }}"
      VIKUNJA_REDIS_ENABLED: "true"
      VIKUNJA_REDIS_HOST: "redis:6379"
      VIKUNJA_SERVICE_TIMEZONE: Europe/Paris

  db:
    image: "postgres:{{ vikunja_postgres_image_tag }}"
    security_opt:
      - no-new-privileges:true
    volumes:
      - ./db_data:/var/lib/postgresql/data
    restart: unless-stopped
    networks:
      - "vikunja_internal"
    environment:
      POSTGRES_DB: vikunja
      POSTGRES_USER: "{{ vikunja_db_user }}"
      POSTGRES_PASSWORD: "{{ vikunja_db_password }}"

  redis:
    image: redis:alpine
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    networks:
      - "vikunja_internal"

networks:
  proxy:
    external: true
  "vikunja_internal":
    name: "vikunja_internal"
    internal: true
