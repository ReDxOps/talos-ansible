---

services:
  "{{ sparkyfitness_role_name }}":
    image: "codewithcj/sparkyfitness_server:{{ sparkyfitness_app_image_tag }}"
    container_name: "{{ sparkyfitness_role_name }}"
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    volumes:
      - ./data/backup:/app/SparkyFitnessServer/backup
      - ./data/uploads:/app/SparkyFitnessServer/uploads
    networks:
      - "{{ sparkyfitness_role_name }}_internal"
    depends_on:
      - "{{ sparkyfitness_role_name }}-db"
    environment:
      SPARKY_FITNESS_LOG_LEVEL: "{{ sparkyfitness_log_level }}"
      ALLOW_PRIVATE_NETWORK_CORS: "{{ sparkyfitness_allow_cors }}"
      SPARKY_FITNESS_EXTRA_TRUSTED_ORIGINS: "{{ sparkyfitness_extra_trusted_origins }}"
      SPARKY_FITNESS_DB_USER: "{{ sparkyfitness_db_user }}"
      SPARKY_FITNESS_DB_HOST: "{{ sparkyfitness_db_host }}"
      SPARKY_FITNESS_DB_NAME: "{{ sparkyfitness_db_name }}"
      SPARKY_FITNESS_DB_PASSWORD: "{{ sparkyfitness_db_password }}"
      SPARKY_FITNESS_APP_DB_USER: "{{ sparkyfitness_app_db_user }}"
      SPARKY_FITNESS_APP_DB_PASSWORD: "{{ sparkyfitness_app_db_password }}"
      SPARKY_FITNESS_DB_PORT: "{{ sparkyfitness_db_port }}"
      SPARKY_FITNESS_API_ENCRYPTION_KEY: "{{ sparkyfitness_api_encryption_key }}"
      BETTER_AUTH_SECRET: "{{ sparkyfitness_better_auth_secret }}"
      SPARKY_FITNESS_FRONTEND_URL: "{{ sparkyfitness_frontend_url }}"
      SPARKY_FITNESS_DISABLE_SIGNUP: "{{ sparkyfitness_disable_signup }}"
      SPARKY_FITNESS_ADMIN_EMAIL: "{{ sparkyfitness_admin_email }}"
      SPARKY_FITNESS_EMAIL_HOST: "{{ sparkyfitness_email_host }}"
      SPARKY_FITNESS_EMAIL_PORT: "{{ sparkyfitness_email_port }}"
      SPARKY_FITNESS_EMAIL_SECURE: "{{ sparkyfitness_email_secure }}"
      SPARKY_FITNESS_EMAIL_USER: "{{ sparkyfitness_email_user }}"
      SPARKY_FITNESS_EMAIL_PASS: "{{ sparkyfitness_email_password }}"
      SPARKY_FITNESS_EMAIL_FROM: "{{ sparkyfitness_email_from }}"
      NODE_ENV: "{{ sparkyfitness_node_env }}"
      PUID: "{{ sparkyfitness_puid }}"
      GUID: "{{ sparkyfitness_guid }}"
      TZ: "{{ sparkyfitness_time_zone }}"

  "{{ sparkyfitness_role_name }}-nginx":
    image: codewithcj/sparkyfitness:{{ sparkyfitness_nginx_image_tag }}
    container_name: "{{ sparkyfitness_role_name }}-nginx"
    security_opt:
      - no-new-privileges:true
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ sparkyfitness_reverse_proxy_network }}"
      - "traefik.http.routers.{{ sparkyfitness_role_name }}.rule=Host(`{{ sparkyfitness_web_url }}`)"
      - "traefik.http.routers.{{ sparkyfitness_role_name }}.entrypoints=websecure"
      - "traefik.http.routers.{{ sparkyfitness_role_name }}.tls=true"
      - "traefik.http.routers.{{ sparkyfitness_role_name }}.tls.certresolver=letsencrypt-dns"
      - "traefik.http.services.{{ sparkyfitness_role_name }}.loadbalancer.server.port=80"
    environment:
      SPARKY_FITNESS_FRONTEND_URL: "{{ sparkyfitness_frontend_url }}"
      SPARKY_FITNESS_SERVER_HOST: "{{ sparkyfitness_role_name }}"
      SPARKY_FITNESS_SERVER_PORT: "{{ sparkyfitness_server_port }}"
      PUID: "{{ sparkyfitness_puid }}"
      GUID: "{{ sparkyfitness_guid }}"
    networks:
      - "{{ sparkyfitness_reverse_proxy_network }}"
      - "{{ sparkyfitness_role_name }}_internal"
    restart: unless-stopped
    depends_on:
      - "{{ sparkyfitness_role_name }}"

  "{{ sparkyfitness_role_name }}-db":
    image: "postgres:{{ sparkyfitness_postgres_image_tag }}"
    container_name: "{{ sparkyfitness_role_name }}-db"
    security_opt:
      - no-new-privileges:true
    restart: unless-stopped
    environment:
      POSTGRES_DB: "{{ sparkyfitness_db_name }}"
      POSTGRES_USER: "{{ sparkyfitness_db_user }}"
      POSTGRES_PASSWORD: "{{ sparkyfitness_db_password }}"
    volumes:
      - ./db_data:/var/lib/postgresql
    networks:
      - "{{ sparkyfitness_role_name }}_internal"

networks:
  "{{ sparkyfitness_reverse_proxy_network }}":
    external: true
  "{{ sparkyfitness_role_name }}_internal":
    name: "{{ sparkyfitness_role_name }}_internal"
