##############################################################
################## HESTIA LOYALTY .env FILE ##################
##############################################################

LANG=C.UTF-8

######## POSTGRES ########

POSTGRES_DB={{ hestia_loyalty_db_name }}
POSTGRES_USER={{ hestia_loyalty_db_user }}
POSTGRES_PASSWORD={{ hestia_loyalty_db_password }}


######## NEXTJS APP ########

NEXT_PUBLIC_APP_URL={{ hestia_loyalty_web_url if app_env == 'prod' else hestia_loyalty_staging_web_url }}
NEXT_PUBLIC_SCAN_URL={{ (hestia_loyalty_web_url if app_env == 'prod' else hestia_loyalty_staging_web_url) }}/scan
AUTH_SECRET={{ hestia_loyalty_nextjs_auth_secret }}
SUPERADMIN_EMAIL={{ hestia_loyalty_superadmin_email }}
SUPERADMIN_PASSWORD={{ hestia_loyalty_superadmin_password }}
DATABASE_URL=postgresql://{{ hestia_loyalty_db_user }}:{{ hestia_loyalty_db_password }}@db:5432/{{ hestia_loyalty_db_name }}?schema=public


######## EMAIL (MAILGUN) ########

EMAIL_PROVIDER={{ hestia_loyalty_email_provider }}
MAILGUN_API_KEY={{ hestia_loyalty_email_provider_api_key }}
MAILGUN_DOMAIN={{ hestia_loyalty_email_provider_domain }}


######## PHONE WALLETS ########

GOOGLE_WALLET_ISSUER_ID={{ hestia_loyalty_google_wallet_issuer_id }}
APPLE_WALLET_PASS_TYPE_ID={{ hestia_loyalty_apple_wallet_pass_type_id }}
APPLE_WALLET_TEAM_ID={{ hestia_loyalty_apple_wallet_team_id }}
APPLE_WALLET_CERT_PATH={{ hestia_loyalty_apple_wallet_cert_path }}
APPLE_WALLET_KEY_PATH={{ hestia_loyalty_apple_wallet_key_path }}
APPLE_WALLET_WWDR_PATH={{ hestia_loyalty_apple_wallet_wwdr_path }}
APPLE_WALLET_KEY_PASSPHRASE={{ hestia_loyalty_apple_wallet_key_passphrase }}

GOOGLE_WALLET_ISSUER_ID={{ hestia_loyalty_google_wallet_issuer_id }}
GOOGLE_WALLET_SERVICE_ACCOUNT_PATH={{ hestia_loyalty_google_wallet_service_account_path }}


######## IA ########

######## IA ########

GEMINI_API_KEY={{ hestia_loyalty_gemini_api_key }}