---
name: "{{ app_name }}-{{ app_env }}"

services:

  app:
{% if app_env != 'prod' %}
    image: "{{ hestia_loyalty_app_image }}:{{ hestia_loyalty_app_staging_image_tag }}"
{% else %}
    image: "{{ hestia_loyalty_app_image }}:{{ hestia_loyalty_app_production_image_tag }}"
{% endif %}
    restart: always
    depends_on:
      db:
        condition: service_healthy

    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    volumes:
      - {{ hestia_loyalty_root_dir }}/{{ app_name }}_data:/app/public/uploads
      - {{ hestia_loyalty_root_dir }}/{{ app_name }}_certs:/app/certs:ro
    networks:
      - internal
      - proxy

    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ hestia_loyalty_reverse_proxy_network }}"
      - "traefik.http.routers.{{ app_name }}-{{ app_env }}.rule=Host(`{{ (hestia_loyalty_web_url if app_env == 'prod' else hestia_loyalty_staging_web_url) | regex_replace('^https?://', '') }}`)"
{% if app_env != 'prod' %}
      - "traefik.http.routers.{{ app_name }}-{{ app_env }}.middlewares=secHeaders@file,tailscaleOnly@file"
{% else %}
      - "traefik.http.routers.{{ app_name }}-{{ app_env }}.middlewares=secHeaders@file"
{% endif %}
      - "traefik.http.routers.{{ app_name }}-{{ app_env }}.entrypoints=websecure"
      - "traefik.http.routers.{{ app_name }}-{{ app_env }}.tls=true"
      - "traefik.http.routers.{{ app_name }}-{{ app_env }}.tls.certresolver=letsencrypt-dns"
      - "traefik.http.services.{{ app_name }}-{{ app_env }}.loadbalancer.server.port=3000"
    deploy:
      replicas: 1
      update_config:
        order: start-first
        failure_action: rollback
        delay: 5s
      resources:
        reservations:
          memory: "{{ hestia_loyalty_ram_reservation }}"
        limits:
          memory: "{{ hestia_loyalty_ram_limit }}"
    cpu_shares: 512
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3000/api/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 20s
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    environment:
      - DATABASE_URL
      - NEXT_PUBLIC_APP_URL
      - NEXT_PUBLIC_SCAN_URL
      - AUTH_SECRET
      - EMAIL_PROVIDER
      - RESEND_API_KEY
      - APPLE_WALLET_PASS_TYPE_ID
      - APPLE_WALLET_TEAM_ID
      - APPLE_WALLET_CERT_PATH
      - APPLE_WALLET_KEY_PATH
      - APPLE_WALLET_WWDR_PATH
      - APPLE_WALLET_KEY_PASSPHRASE
      - SUPERADMIN_EMAIL
      - SUPERADMIN_PASSWORD
      - LANG
      - GEMINI_API_KEY
      - GOOGLE_WALLET_ISSUER_ID
      - GOOGLE_WALLET_SERVICE_ACCOUNT_PATH

  db:
    image: "{{ hestia_loyalty_db_image }}:{{ hestia_loyalty_db_tag }}"
    restart: always

    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - DAC_OVERRIDE
      - SETGID
      - SETUID
      - FOWNER
    security_opt:
      - no-new-privileges:true
    volumes:
      - db_data:/var/lib/postgresql
    networks:
      - internal
    labels:
      - "kopia.backup.target=true"
    deploy:
      resources:
        reservations:
          memory: "{{ hestia_loyalty_db_ram_reservation }}"
        limits:
          memory: "{{ hestia_loyalty_db_ram_limit }}"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER} -d $${POSTGRES_DB}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    environment:
      - POSTGRES_PASSWORD
      - POSTGRES_USER
      - POSTGRES_DB
      - LANG


networks:
  internal:
    internal: true
  proxy:
    name: "{{ hestia_loyalty_reverse_proxy_network }}"
    external: true

volumes:
  db_data:
