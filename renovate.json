{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "schedule:weekends"
    ],
    "packageRules": [
        {
            "groupName": "Non-major updates",
            "minimumReleaseAge": "3 days",
            "matchUpdateTypes": [
                "minor",
                "patch"
            ]
        },
        {
            "groupName": "Ansible Roles & Collections",
            "matchManagers": ["ansible-galaxy"],
            "matchUpdateTypes": ["minor", "patch"]
        },
        {
            "groupName": "Ansible Tooling",
            "matchManagers": ["pip_requirements"],
            "matchPackageNames": ["ansible-core"],
            "allowedVersions": "< 2.20.0"
        },
        {
            "groupName": "Ansible Tooling",
            "matchManagers": ["pip_requirements"],
            "matchPackageNames": ["ansible-lint"]
        },
        {
            "groupName": "CI Tooling",
            "matchManagers": ["github-actions"],
            "matchPackageNames": ["python"],
            "allowedVersions": "< 3.12.0"
        }
    ],
    "customManagers": [
        {
        "customType": "regex",
        "managerFilePatterns": [
                "/(^|/)img_and_versions\\.yml$/"
            ],
        "matchStrings": ["# renovate: datasource=(?<datasource>.*?)\\n.*?\\\"(?<depName>.*?)\\\"\\n.*?\\\"(?<currentValue>.*?)\\\""]
        }
    ]
}
